{
  "name": "@muzikanto/nestjs-openai",
  "version": "1.0.1",
  "description": "NestJS module for openai",
  "keywords": [
    "nestjs",
    "nestjs module",
    "openai",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "prettier --check 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'README.md'",
    "ch": "changeset",
    "vers": "changeset version",
    "pub": "changeset publish"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "openai": "^6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "@types/node": "^20.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "maintainers": [
    {
      "name": "Maxim Schiriy"
    }
  ],
  "homepage": "https://github.com/Muzikanto/nestjs-openai#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Muzikanto/nestjs-openai"
  },
  "bugs": {
    "url": "https://github.com/Muzikanto/nestjs-openai/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
